{
  "name": "@swipehire/api",
  "version": "2.0.0-dev",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/index.ts",
    "build": "tsc -p tsconfig.json --noEmit",
    "start": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "ingest:greenhouse": "tsx --env-file=../../.env scripts/ingestGreenhouse.ts",
    "ingest:dol": "tsx --env-file=../../.env scripts/ingestDol.ts",
    "discover:ats": "tsx --env-file=../../.env scripts/discoverAts.ts",
    "ingest:all-ats": "tsx --env-file=../../.env scripts/ingestAllAts.ts"
  },
  "dependencies": {
    "@aws-sdk/client-ses": "^3.1047.0",
    "@neondatabase/serverless": "^0.10.4",
    "@swipehire/db": "workspace:*",
    "@swipehire/shared": "workspace:*",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.20.0",
    "cheerio": "^1.1.0",
    "connect-pg-simple": "^10.0.0",
    "cors": "^2.8.6",
    "docx": "^9.6.1",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.39.1",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "express-session": "^1.18.1",
    "ioredis": "^5.4.1",
    "mammoth": "^1.12.0",
    "memorystore": "^1.6.7",
    "multer": "^2.1.1",
    "node-cron": "^4.1.1",
    "openai": "^5.8.2",
    "openid-client": "^6.6.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-local": "^1.0.0",
    "pdf-parse": "^2.4.5",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "playwright": "^1.49.0",
    "undici": "^7.2.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/cors": "^2.8.19",
    "@types/express": "4.17.21",
    "@types/express-session": "^1.18.2",
    "@types/multer": "^1.4.13",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.16",
    "@types/passport-local": "^1.0.38",
    "@types/pdf-parse": "^1.1.5",
    "@vitest/ui": "^2.1.8",
    "tsx": "^4.19.1",
    "typescript": "5.6.3",
    "vitest": "^2.1.8"
  }
}
