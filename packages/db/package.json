{
  "name": "@swipehire/db",
  "version": "2.0.0-dev",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./schema/v1": "./src/schema/v1.ts",
    "./schema/v2": "./src/schema/v2.ts"
  },
  "scripts": {
    "generate": "drizzle-kit generate --config=drizzle.config.cjs",
    "push": "drizzle-kit push --config=drizzle.config.cjs",
    "migrate": "tsx src/migrate.ts",
    "seed": "tsx src/seed.ts",
    "studio": "drizzle-kit studio --config=drizzle.config.cjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.10.4",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.39.1",
    "drizzle-zod": "^0.7.0",
    "pg": "^8.13.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.30.4",
    "tsx": "^4.19.1",
    "typescript": "5.6.3"
  }
}
