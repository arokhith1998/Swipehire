# =====================================================================
# SwipeHire v2 — Environment Configuration
# Copy to .env and fill in actual values for local development.
# =====================================================================

# --- Core ---
NODE_ENV=development
LOG_LEVEL=debug
PORT=5000

# --- Database (Neon Postgres + pgvector) ---
DATABASE_URL=postgresql://swipehire:swipehire@localhost:5433/swipehire
# In docker-compose.yml the local Postgres is preconfigured with pgvector.
# Port 5433 is used to avoid conflicting with any native Postgres install on 5432.

# --- Session ---
SESSION_SECRET=change-me-to-a-real-random-secret-in-production
SESSION_STORE=postgres   # postgres | memory (memory only for dev)

# --- Redis (BullMQ + cache) ---
REDIS_URL=redis://localhost:6379

# --- ML Sidecar ---
ML_SIDECAR_URL=http://localhost:8001
ML_SIDECAR_TIMEOUT_MS=2000
ML_FALLBACK_ENABLED=true

# --- Object Storage (Cloudflare R2 or S3) ---
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=swipehire-resumes
S3_REGION=auto

# --- OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# --- LLM Providers (resume tailoring) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_PROVIDER=openai      # openai | anthropic

# --- Job Aggregator APIs (v1 sources, kept) ---
JSEARCH_API_KEY=
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# --- ATS APIs (Phase 2 / Phase 3) ---
GREENHOUSE_HARVEST_API_KEY=    # for recruiter-side write-back
LEVER_API_KEY=
ASHBY_API_KEY=

# --- Feature Flags ---
USE_V2_MATCHER=false           # gradually enable v2 scoring
USE_V2_TAILORING=false
USE_V2_LIVENESS=true           # liveness checker is safe to enable immediately
USE_V2_VISA=false              # waits for first DOL ingest

# --- Honesty Dashboard ---
HONESTY_DASHBOARD_PUBLIC=true

# --- Telemetry ---
OTEL_EXPORTER_OTLP_ENDPOINT=
SENTRY_DSN=

# --- Worker config ---
WORKER_CONCURRENCY=2
LIVENESS_CHECK_INTERVAL_HOURS=24
DOL_INGEST_CHECK_INTERVAL_HOURS=168
