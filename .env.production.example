# =====================================================================
# SwipeHire v2 — PRODUCTION env template
# Copy to your hosting providers (Railway → both services; Vercel → web).
# Never commit a filled-in copy. .env.production is in .gitignore.
# =====================================================================

# --- Core (Railway: api + worker) ---
NODE_ENV=production
LOG_LEVEL=info
PORT=5000                              # Railway injects PORT automatically; this is a fallback

# --- Database (Neon Postgres + pgvector) ---
# From Neon dashboard → "Connection string" → Pooled. Append ?sslmode=require if not present.
DATABASE_URL=postgresql://USER:PASS@HOST.neon.tech/DBNAME?sslmode=require

# --- Sessions (api) ---
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=GENERATE_NEW_HEX_HERE
SESSION_STORE=postgres
COOKIE_DOMAIN=.swipehire.io           # Allows cookie shared between app.swipehire.io ↔ api.swipehire.io

# --- CORS (api) ---
# Include every host the SPA can be reached from. www.swipehire.io is an alias
# for app.swipehire.io (Vercel 308-redirects www → app), but if a user lands on
# www first the browser uses that origin for the first XHR.
CORS_ORIGINS=https://app.swipehire.io,https://www.swipehire.io,https://swipehire.io

# --- Redis (Upstash, BullMQ + cache; worker primarily) ---
# Use the "rediss://" connection string from Upstash for TLS.
REDIS_URL=rediss://default:PASS@HOST.upstash.io:6379

# --- ML Sidecar (skip for v0 beta — calibrator falls back gracefully) ---
ML_SIDECAR_URL=
ML_SIDECAR_TIMEOUT_MS=2000
ML_FALLBACK_ENABLED=true

# --- OAuth (set when Google sign-in is wired) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://api.swipehire.io/api/auth/google/callback

# --- LLM Providers (resume tailoring — deferred past beta) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_PROVIDER=openai

# --- Feature Flags ---
USE_V2_MATCHER=true
USE_V2_TAILORING=false
USE_V2_LIVENESS=true
USE_V2_VISA=false                     # Flip on once DOL ingest has run

# --- Honesty Dashboard ---
HONESTY_DASHBOARD_PUBLIC=true

# --- Worker config ---
WORKER_CONCURRENCY=2
LIVENESS_CHECK_INTERVAL_HOURS=24

# --- Transactional email (Amazon SES) ---
# IAM user needs ses:SendEmail. EMAIL_FROM must be SES-verified.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
EMAIL_FROM=SwipeHire <hello@swipehire.io>
APP_URL=https://app.swipehire.io

# =====================================================================
# Vercel-only env vars (set these in Vercel project settings, NOT Railway)
# =====================================================================
# VITE_API_URL=https://api.swipehire.io
